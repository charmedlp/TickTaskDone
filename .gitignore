# =============================================================================
#  Dépendances
# =============================================================================
node_modules/
.pnp
.pnp.*

# =============================================================================
#  Variables d'environnement (NE JAMAIS committer)
# =============================================================================
.env
.env.*
!.env.example

# =============================================================================
#  Sorties de build
# =============================================================================
dist/
dist-ssr/
build/
*.tsbuildinfo
*.local

# =============================================================================
#  Logs
# =============================================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =============================================================================
#  Tests / couverture
# =============================================================================
coverage/
.nyc_output/

# =============================================================================
#  Drizzle
#  (les migrations générées DOIVENT être committées — on n'ignore que le cache)
# =============================================================================
.drizzle/

# =============================================================================
#  Capacitor / Android
#  (le dossier android/ source est committé ; on ignore les artefacts de build)
# =============================================================================
frontend/android/.gradle/
frontend/android/build/
frontend/android/app/build/
frontend/android/app/release/
frontend/android/local.properties
frontend/android/.idea/
frontend/android/captures/
*.iml
*.keystore
!debug.keystore

# Capacitor copie le build web ici — régénérable
frontend/android/app/src/main/assets/public/
frontend/ios/App/App/public/

# =============================================================================
#  Éditeurs / IDE
# =============================================================================
.vscode/
.idea/
*.swp
*.swo

# =============================================================================
#  Système d'exploitation
# =============================================================================
.DS_Store
Thumbs.db