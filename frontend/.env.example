# Base URL for API calls. Direct to the backend bypasses the Vite dev proxy (lower
# latency, immune to Vite rebuilds). Use /api to route through the Vite proxy instead.
VITE_API_BASE_URL=http://localhost:3000

# Current workspace id. Temporary stand-in for the workspace that authentication
# will provide (Phase 10); mirrors the backend's hard-coded dev user (idWorkspace=1).
VITE_WORKSPACE_ID=1
