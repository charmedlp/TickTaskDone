# Connexion MySQL — format : mysql://utilisateur:motdepasse@hote:port/base
DATABASE_URL=mysql://root:password@localhost:3306/ticktaskdone

# Port du serveur Express
PORT=3000

# Utilisateur de développement injecté par le middleware currentUser temporaire
# (créé par `npm run db:seed`). Remplacé par la vraie authentification en Phase 10.
DEV_USER_EMAIL=dev@ticktaskdone.local
